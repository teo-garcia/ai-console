#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DATADOG_MCP_URL="https://mcp.us5.datadoghq.com/api/unstable/mcp-server/mcp"

failures=0
warnings=0

ok() {
  echo "ok: $1"
}

warn() {
  warnings=$((warnings + 1))
  echo "warn: $1"
}

fail() {
  failures=$((failures + 1))
  echo "fail: $1"
}

check_exists() {
  local path="$1"
  if [[ -e "$path" ]]; then
    ok "exists $path"
  else
    fail "missing $path"
  fi
}

check_symlink_target() {
  local path="$1"
  if [[ -L "$path" ]]; then
    if [[ -e "$path" ]]; then
      ok "symlink target resolves $path"
    else
      fail "broken symlink $path"
    fi
  else
    warn "not a symlink $path"
  fi
}

check_json() {
  local path="$1"
  if python3 -m json.tool "$path" >/dev/null 2>&1; then
    ok "valid json $path"
  else
    fail "invalid json $path"
  fi
}

check_toml() {
  local path="$1"
  local status
  status="$(python3 - "$path" <<'PY'
import pathlib
import sys

try:
    import tomllib  # type: ignore[attr-defined]
except ModuleNotFoundError:
    try:
        import tomli as tomllib
    except ModuleNotFoundError:
        print("missing-parser")
        sys.exit(0)

path = pathlib.Path(sys.argv[1])

try:
    tomllib.loads(path.read_text(encoding="utf-8"))
except Exception:
    print("invalid")
    sys.exit(0)

print("valid")
PY
)"

  case "$status" in
    valid)
      ok "valid toml $path"
      ;;
    invalid)
      fail "invalid toml $path"
      ;;
    missing-parser)
      warn "skipped toml validation for $path because no TOML parser is available in python3"
      ;;
    *)
      fail "unexpected toml validation status for $path: $status"
      ;;
  esac
}

check_placeholder_tokens() {
  local path="$1"
  if rg -n --fixed-strings 'your_token' "$path" >/dev/null 2>&1; then
    warn "placeholder token found in $path"
  else
    ok "no your_token placeholder in $path"
  fi

  if rg -n --fixed-strings 'your_key' "$path" >/dev/null 2>&1; then
    warn "placeholder key found in $path"
  else
    ok "no your_key placeholder in $path"
  fi
}

check_machine_path() {
  local path="$1"
  if rg -n '/Users/' "$path" >/dev/null 2>&1; then
    warn "machine specific path found in $path"
  else
    ok "no machine specific /Users path in $path"
  fi
}

check_datadog_mcp() {
  local path="$1"
  if [[ "$path" == *.json ]]; then
    if python3 - "$path" "$DATADOG_MCP_URL" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
expected_url = sys.argv[2]

try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(1)

server = data.get("mcpServers", {}).get("datadog", {})
sys.exit(0 if server.get("url") == expected_url else 1)
PY
    then
      ok "Datadog MCP uses US5 endpoint in $path"
    else
      fail "Datadog MCP US5 endpoint missing in $path"
    fi
  elif awk -v url="$DATADOG_MCP_URL" '
    $0 == "[mcp_servers.datadog]" { in_datadog = 1; found = 1; next }
    /^\[mcp_servers\./ { in_datadog = 0 }
    in_datadog && $0 == "url = \"" url "\"" { url_found = 1 }
    END { exit !(found && url_found) }
  ' "$path"; then
    ok "Datadog MCP uses US5 endpoint in $path"
  else
    fail "Datadog MCP US5 endpoint missing in $path"
  fi

  if rg -n 'https://(mcp|app|api)\.datadoghq\.com' "$path" >/dev/null 2>&1; then
    fail "Datadog MCP uses a disallowed Datadog host in $path"
  else
    ok "no disallowed Datadog MCP host in $path"
  fi
}

echo "verify: checking ai-console templates"

check_exists "$ROOT/mcp/codex.config.toml"
check_exists "$ROOT/mcp/claude.mcp.json"
check_exists "$ROOT/mcp/cursor.mcp.json"
check_exists "$ROOT/mcp/gemini.settings.json"
check_exists "$ROOT/config/targets.json"
check_exists "$ROOT/registry/repos.json"
check_exists "$ROOT/rulesets/core/codex/AGENTS.md"
check_exists "$ROOT/rulesets/core/claude/CLAUDE.md"
check_exists "$ROOT/rulesets/core/cursor/rules/core.mdc"
check_exists "$ROOT/rulesets/core/gemini/GEMINI.md"

check_symlink_target "$ROOT/AGENTS.md"
check_symlink_target "$ROOT/CLAUDE.md"
check_symlink_target "$ROOT/GEMINI.md"
check_symlink_target "$ROOT/mcp.json"
check_symlink_target "$ROOT/.mcp.json"
check_symlink_target "$ROOT/.cursor/rules"
check_symlink_target "$ROOT/.gemini/settings.json"

check_json "$ROOT/mcp/claude.mcp.json"
check_json "$ROOT/mcp/cursor.mcp.json"
check_json "$ROOT/mcp/gemini.settings.json"
check_json "$ROOT/config/targets.json"
check_json "$ROOT/registry/repos.json"
check_toml "$ROOT/mcp/codex.config.toml"

check_placeholder_tokens "$ROOT/mcp/codex.config.toml"
check_placeholder_tokens "$ROOT/mcp/claude.mcp.json"
check_placeholder_tokens "$ROOT/mcp/cursor.mcp.json"
check_placeholder_tokens "$ROOT/mcp/gemini.settings.json"
check_machine_path "$ROOT/mcp/codex.config.toml"
check_datadog_mcp "$ROOT/mcp/codex.config.toml"
check_datadog_mcp "$ROOT/mcp/claude.mcp.json"
check_datadog_mcp "$ROOT/mcp/cursor.mcp.json"
check_datadog_mcp "$ROOT/mcp/gemini.settings.json"

echo "verify: complete (failures=$failures warnings=$warnings)"

if [[ $failures -gt 0 ]]; then
  exit 1
fi
